<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Home – Kindle Apps</title>
    <link rel="stylesheet" href="/static/style.css">
</head>
<body>
    <div class="page">
        <h1>📱 Le mie App</h1>
        <p class="subtitle">Scegli un'applicazione</p>

        <div class="app-grid">
            <a href="/sleep" class="app-card blue">
                <span class="app-icon">🌙</span>
                <span class="app-name">Sleep Tracker</span>
                <span class="app-desc">Traccia il tuo sonno</span>
            </a>

            <a href="#" class="app-card yellow disabled">
                <span class="app-icon">✅</span>
                <span class="app-name">Abitudini</span>
                <span class="app-desc">Prossimamente</span>
            </a>

            <a href="#" class="app-card green disabled">
                <span class="app-icon">📝</span>
                <span class="app-name">Note</span>
                <span class="app-desc">Prossimamente</span>
            </a>
        </div>
    </div>
</body>
</html>
